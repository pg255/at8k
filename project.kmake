#version 1.0


#global
	sources: "src"
	headers: "include"
	
	binarytype: executable
	binaryname: at8k
	
	standard: c++23
	compiler: g++
	compilerlauncher: ccache
	compileflags: -embed-dir=templates
	
	customflags: export-compile-commands, export-vscode-sln


#profile debug-linux
	buildtype: debug
	buildpath: "build/debug-linux"
	
#profile release-linux
	buildtype: release
	buildpath: "build/release-linux"